{%- liquid
  assign background_color = '#FAA41A'
  assign text_color = '#FFFFFF'
  assign border_color = '#FAA41A'
  assign hover_background_color = '#F4AE3C'
  assign hover_text_color = '#FFFFFF'
  assign hover_border_color = '#F4AE3C'
-%}

<style>
  /* Header specific styles */
  .site-header {
    background-color: #FFFFFF; /* Ensure white header background for visibility */
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 40px;
    border-bottom: 1px solid #e0e0e0; /* Optional: light border for separation */
    height: 100px; /* Adjust header height as needed */
  }

  .site-header__logo-container {
    display: flex;
    align-items: center;
    margin-right: auto; /* Push navigation to the center */
  }

  .site-header__logo-image {
    max-height: 80px; /* Adjust logo height as needed */
  }

  /* Navigation styles */
  .site-nav {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav__item {
    margin: 0 15px;
    position: relative;
  }

  .site-nav__link {
    text-decoration: none;
    color: #444444; /* Standard grey for links */
    font-family: Arial, sans-serif;
    font-size: 16px;
    display: flex;
    align-items: center;
  }

  /* Dropdown icon and styles */
  .site-nav__link .icon-dropdown {
    margin-left: 5px;
    font-size: 12px;
  }

  .site-nav__item--has-dropdown .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: #FFFFFF;
    border: 1px solid #e0e0e0;
    padding: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    z-index: 100;
  }

  .site-nav__item--has-dropdown:hover .dropdown-menu {
    display: block;
  }

  /* Icons and Call to Action Styles */
  .header-actions {
    display: flex;
    align-items: center;
  }

  .icon-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    margin-right: 20px;
  }

  .icon-list__item {
    margin-left: 15px;
  }

  .icon-list__link {
    text-decoration: none;
    color: #444444;
    font-size: 20px;
    display: flex;
    align-items: center;
    position: relative;
  }

  /* Bag badge */
  .bag-count {
    background-color: {{ background_color }};
    color: {{ text_color }};
    font-size: 12px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    position: absolute;
    top: -8px;
    right: -10px;
  }

  /* Primary Button - Create a Book */
  .create-book-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: 'Open Sans', sans-serif;
    font-size: 16px;
    padding: 12px 24px;
    background-color: {{ background_color }};
    color: {{ text_color }};
    border: 2px solid {{ border_color }};
    border-radius: 5px; /* Adjust border-radius as needed */
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  .create-book-btn__icon {
    margin-right: 10px;
    font-size: 18px;
  }

  .create-book-btn:hover {
    background-color: {{ hover_background_color }};
    color: {{ hover_text_color }};
    border-color: {{ hover_border_color }};
  }

  /* SVG Icons */
  .icon-search:before { content: "\f002"; font-family: FontAwesome; }
  .icon-user:before { content: "\f007"; font-family: FontAwesome; }
  .icon-bag:before { content: "\f290"; font-family: FontAwesome; }
  .icon-dropdown:before { content: "\f107"; font-family: FontAwesome; }
  .icon-plus:before { content: "\f067"; font-family: FontAwesome; } /* Icon for Create a Book button */
</style>

<header class="site-header" role="banner">
  <div class="site-header__logo-container">
    <a href="/" class="site-header__logo-link">
      <img src="{{ 'picture-books-logo.png' | asset_img_url: 'master' }}" alt="Picture Books Logo" class="site-header__logo-image">
    </a>
  </div>

  <nav class="site-nav" role="navigation">
    <ul class="site-nav__list">
      <li class="site-nav__item">
        <a href="/collections/all" class="site-nav__link">Products</a>
      </li>
      <li class="site-nav__item">
        <a href="/pages/contact" class="site-nav__link">Contact</a>
      </li>
      <li class="site-nav__item site-nav__item--has-dropdown">
        <a href="#" class="site-nav__link">Discover <span class="icon-dropdown"></span></a>
        <ul class="dropdown-menu">
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/blogs/news">Blog</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </li>
    </ul>
  </nav>

  <div class="header-actions">
    <ul class="icon-list">
      <li class="icon-list__item">
        <a href="/search" class="icon-list__link"><span class="icon-search"></span></a>
      </li>
      <li class="icon-list__item">
        <a href="/account/login" class="icon-list__link"><span class="icon-user"></span></a>
      </li>
      <li class="icon-list__item">
        <a href="/cart" class="icon-list__link">
          <span class="icon-bag"></span>
          <span class="bag-count">2</span> </a>
      </li>
    </ul>

    <a href="/pages/create-a-book" class="create-book-btn">
      <span class="create-book-btn__icon icon-plus"></span>
      Create a Book
    </a>
  </div>
</header>