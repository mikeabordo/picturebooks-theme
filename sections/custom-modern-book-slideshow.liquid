{%- style -%}
  .book-slideshow-wrap {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 0;
    overflow: hidden;
  }

  .book-slider {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s;
    text-align: center;
  }

  .book-slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .book-slide__image {
    width: 100%;
    height: 70%;
    display: flex;
    justify-content: center;
    margin-bottom: -30px;
  }

  .book-slide__image img {
    max-height: 100%;
    width: auto;
    object-fit: contain;
    transition: transform 5s ease;
  }

  .book-slide.is-active img {
    transform: scale(1.05);
  }

  .book-slide__card {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 30px;
    border-radius: 20px;
    width: 90%;
    max-width: 400px;
    z-index: 3;
    color: {{ section.settings.text_color }};
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .book-slide__heading {
    font-family: serif;
    font-size: 2.2rem;
    margin: 0 0 10px 0;
  }

  .book-slide__description {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 20px;
  }

  .book-slide__btn {
    display: inline-block;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 12px 30px;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    transition: transform 0.3s ease;
  }

  /* Navigation: Dots */
  .book-slider__nav {
    position: absolute;
    bottom: 8px;
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .nav-dot {
    width: 8px;
    height: 8px;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .nav-dot.is-selected {
    background: {{ section.settings.text_color }};
    transform: scale(1.3);
  }

  /* Navigation: Arrows */
  .book-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: {{ section.settings.text_color }};
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    transition: 0.3s;
  }

  .book-slider__arrow:hover { background: #FAA41A; }
  .book-slider__arrow:hover svg { stroke: white; }
  .book-slider__arrow--prev { left: 20px; }
  .book-slider__arrow--next { right: 20px; }
  .book-slider__arrow svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 2.5; }
{%- endstyle -%}

<div class="book-slideshow-wrap">
  <div class="book-slider" id="Slider-{{ section.id }}">
    
    {%- for block in section.blocks -%}
      <div class="book-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="book-slide__image">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="book-slide__card">
          <h2 class="book-slide__heading">{{ block.settings.heading | escape }}</h2>
          {%- if block.settings.description != blank -%}
            <p class="book-slide__description">{{ block.settings.description | escape }}</p>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="book-slide__btn">{{ block.settings.btn_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if section.blocks.size > 1 -%}
      <button class="book-slider__arrow book-slider__arrow--prev" aria-label="Previous">
        <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="book-slider__arrow book-slider__arrow--next" aria-label="Next">
        <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
      </button>

      <div class="book-slider__nav">
        {%- for block in section.blocks -%}
          <button class="nav-dot {% if forloop.first %}is-selected{% endif %}" data-index="{{ forloop.index0 }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function() {
    const initSlider = () => {
      const container = document.querySelector('#Slider-{{ section.id }}');
      if (!container) return;
      
      const slides = container.querySelectorAll('.book-slide');
      const dots = container.querySelectorAll('.nav-dot');
      const prevBtn = container.querySelector('.book-slider__arrow--prev');
      const nextBtn = container.querySelector('.book-slider__arrow--next');
      
      let current = 0;
      let timer;

      const update = (index) => {
        if (index >= slides.length) index = 0;
        if (index < 0) index = slides.length - 1;

        slides.forEach(s => s.classList.remove('is-active'));
        dots.forEach(d => d.classList.remove('is-selected'));
        
        slides[index].classList.add('is-active');
        if(dots[index]) dots[index].classList.add('is-selected');
        
        current = index;
        startAutoplay();
      };

      const startAutoplay = () => {
        clearInterval(timer);
        timer = setInterval(() => update(current + 1), 5000);
      };

      dots.forEach(dot => dot.addEventListener('click', () => update(parseInt(dot.dataset.index))));
      if (prevBtn) prevBtn.addEventListener('click', () => update(current - 1));
      if (nextBtn) nextBtn.addEventListener('click', () => update(current + 1));

      startAutoplay();
    };

    document.addEventListener('DOMContentLoaded', initSlider);
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', initSlider);
    }
  })();
</script>

{% schema %}
{
  "name": "Modern Book Slideshow",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#121212" },
    { "type": "color", "id": "btn_bg_color", "label": "Button Background Color", "default": "#FAA41A" },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Book Cover" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Fiction" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Add a short description about this category." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Shop Now" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modern Book Slideshow",
      "blocks": [ { "type": "slide" }, { "type": "slide" } ]
    }
  ]
}
{% endschema %}