m-header-wrap {\n      display: block;\n    }\n\n    .support-right {\n      text-align: left;\n      margin: 12px 0 0;\n    }\n\n    .custom-shopify-menu .menu-root {\n      display: block;\n    }\n\n    .custom-shopify-menu .menu-item {\n      position: static;\n    }\n\n    .custom-shopify-menu .submenu,\n    .custom-shopify-menu .submenu .submenu {\n      display: block;\n      position: static;\n      min-width: 0;\n      border: 0;\n      box-shadow: none;\n      padding-left: 16px;\n    }\n\n    .custom-shopify-menu a {\n      padding: 10px 0;\n    }\n  }\n</style>\n\n<div class=\"custom-header-wrap\">\n  <nav class=\"custom-shopify-menu\" aria-label=\"Main menu\">\n    <ul class=\"menu-root\">\n      {% for link in linklists['main-menu'].links %}\n        <li class=\"menu-item\">\n          <a\n            href=\"{{ link.url }}\"\n            class=\"{% if link.active or link.child_active %}is-active{% endif %}\"\n            {% if link.current %}aria-current=\"page\"{% endif %}\n          >\n            {{ link.title }}\n            {% if link.links != blank %}<span class=\"arrow\">▾</span>{% endif %}\n          </a>\n\n          {% if link.links != blank %}\n            <ul class=\"submenu\">\n              {% for child_link in link.links %}\n                <li class=\"menu-item\">\n                  <a\n                    href=\"{{ child_link.url }}\"\n                    class=\"{% if child_link.active or child_link.child_active %}is-active{% endif %}\"\n                    {% if child_link.current %}aria-current=\"page\"{% endif %}\n                  >\n                    {{ child_link.title }}\n                    {% if child_link.links != blank %}<span class=\"arrow\">▸</span>{% endif %}\n                  </a>\n\n                  {% if child_link.links != blank %}\n                    <ul class=\"submenu\">\n                      {% for grandchild_link in child_link.links %}\n                        <li class=\"menu-item\">\n                     