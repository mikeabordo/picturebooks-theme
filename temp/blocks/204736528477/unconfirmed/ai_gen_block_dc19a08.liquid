{% doc %}
  @prompt
    Build section or block named "custom-grid.liquid" 
    
    requirements:
    3 item grid or more
    item title below the image
    description below the item title
    IMPORTANT: DO THIS IN SINGLE FILE
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-custom-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-custom-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-custom-grid__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-custom-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-custom-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-custom-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-custom-grid__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-custom-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-custom-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'item_' | append: i | append: '_image'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
      %}
      
      {% if item_image != blank or item_title != blank or item_description != blank %}
        <div class="ai-custom-grid__item-{{ ai_gen_id }}">
          <div class="ai-custom-grid__image-wrapper-{{ ai_gen_id }}">
            {% if item_image != blank %}
              <img
                src="{{ item_image | image_url: width: 800 }}"
                alt="{{ item_image.alt | escape }}"
                loading="lazy"
                width="{{ item_image.width }}"
                height="{{ item_image.height }}"
                class="ai-custom-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-custom-grid__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-custom-grid__content-{{ ai_gen_id }}">
            {% if item_title != blank %}
              <h3 class="ai-custom-grid__title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}
            
            {% if item_description != blank %}
              <div class="ai-custom-grid__description-{{ ai_gen_id }}">{{ item_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

